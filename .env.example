# =============================================
# Responsible AI Healthcare Framework — Env
# Copy this to .env and fill in your keys
# NEVER commit .env to Git
# =============================================

# Groq (free LLM inference) — console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# Supabase (free PostgreSQL) — supabase.com
# Get from: Project Settings → API
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_ANON_KEY=eyJ_your_anon_key_here
SUPABASE_SERVICE_KEY=eyJ_your_service_role_key_here

# App settings
APP_ENV=development
SECRET_KEY=change_me_to_a_random_32_char_string
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Guardrail settings
HALLUCINATION_SAMPLES=3
HALLUCINATION_THRESHOLD=0.4

# Bias metrics
BIAS_DISPARITY_THRESHOLD=0.10
